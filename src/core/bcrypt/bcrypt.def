    BCryptDecrypt
    BCryptGenerateSymmetricKey
    BCryptGenerateKeyPair
    BCryptFinalizeKeyPair
    BCryptExportKey
    BCryptImportKey
    BCryptSignHash
    BCryptSecretAgreement
